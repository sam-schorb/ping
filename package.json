{
  "name": "ping",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "start": "npm run start -w apps/web",
    "test:dough": "npm --prefix dough test",
    "test": "npm run -ws --if-present test",
    "lint": "npm run -ws --if-present lint"
  }
}
